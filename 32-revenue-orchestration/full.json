    {
      "parameters": {
        "jsCode": "const ctx = $('Merge MCP Results').first().json;\nlet raw = $json.output || '';\nraw = String(raw).replace(/```json|```/g, '').trim();\n\n// Detect truncated JSON early with a clear message\nif (!raw.endsWith('}')) {\n  throw new Error(`Agent output appears truncated (doesn't end with '}'). Last 100 chars: \"${raw.slice(-100)}\". Bump max_tokens on the Anthropic Chat Model node.`);\n}\n\nlet proposal;\ntry { proposal = JSON.parse(raw); }\ncatch(e) { throw new Error('Agent did not return valid JSON: ' + raw.slice(0,300)); }\n\n// Resume URL — replace localhost if the override is set in Set Target\nlet resumeUrl = $execution.resumeUrl;\nif (!resumeUrl) {\n  throw new Error('No resumeUrl available — make sure a Wait node is downstream');\n}\nconst target = $('Set Target').first().json;\nif (target.n8n_public_base && resumeUrl.includes('localhost')) {\n  resumeUrl = resumeUrl.replace(/https?:\\/\\/localhost:\\d+/, target.n8n_public_base);\n}\n\n// resumeUrl already has ?signature=... so we need & for additional params\nconst sep = resumeUrl.includes('?') ? '&' : '?';\n\nconst blocks = [\n  { type: 'header', text: { type: 'plain_text', text: `🤖 Agent Proposal — ${ctx.opportunity_name}` } },\n  { type: 'section', text: { type: 'mrkdwn', text: `*Signal:* ${ctx.signal_type}\\n*Summary:* ${proposal.summary}` } },\n  { type: 'divider' },\n  { type: 'section', text: { type: 'mrkdwn', text: `*📝 Proposed CRM Update*\\n*Field:* \\`${proposal.crm_update.field}\\`\\n*Value:* ${proposal.crm_update.value}\\n_Rationale: ${proposal.crm_update.rationale}_` } },\n  { type: 'section', text: { type: 'mrkdwn', text: `*💬 Proposed Slack DM to Deal Owner*\\n>>> ${proposal.slack_message.message}\\n_Rationale: ${proposal.slack_message.rationale}_` } },\n  { type: 'divider' },\n  { type: 'actions', elements: [\n    { type: 'button', style: 'primary', text: { type: 'plain_text', text: '✅ Approve Both' }, url: `${resumeUrl}${sep}decision=approve` },\n    { type: 'button', style: 'danger', text: { type: 'plain_text', text: '❌ Reject' }, url: `${resumeUrl}${sep}decision=reject` }\n  ]},\n  { type: 'context', elements: [{ type: 'mrkdwn', text: `_Approval-gated · Execution: ${$execution.id} · Resume: ${resumeUrl.includes('localhost') ? '⚠️ LOCALHOST' : 'OK'}_` }] }\n];\n\nreturn [{ json: {\n  ...ctx,\n  proposal,\n  blocks,\n  blocksJson: JSON.stringify(blocks),\n  resumeUrl\n}}];"
      },
