    {
      "parameters": {
        "jsCode": "// Parse top_records response, extract opportunities sorted by lowest engagement (highest risk)\nconst raw = $json;\nlet payload = raw;\nif (raw.content && Array.isArray(raw.content) && raw.content[0]) {\n  const t = raw.content[0].text;\n  payload = (typeof t === 'string') ? JSON.parse(t) : t;\n}\n\nconst accounts = Array.isArray(payload) ? payload : (payload?.accounts || []);\n\n// Flatten to opportunities with account context\nconst opps = [];\nfor (const acc of accounts) {\n  for (const opp of (acc.opportunities || [])) {\n    opps.push({\n      peopleai_opportunity_id: opp.peopleai_opportunity_id,\n      opportunity_name: opp.opportunity_name,\n      peopleai_account_id: acc.peopleai_account_id,\n      account_name: acc.name,\n      amount: opp.amount,\n      engagement_level: opp.engagement_level,\n      close_date: opp.close_date,\n      owner: opp.owner?.name\n    });\n  }\n}\n\n// Pick top 5 at-risk (lowest engagement)\nconst atRisk = opps\n  .sort((a, b) => (a.engagement_level || 0) - (b.engagement_level || 0))\n  .slice(0, 5);\n\nreturn atRisk.map(o => ({ json: o }));"
      },
