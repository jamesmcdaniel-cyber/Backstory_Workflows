    {
      "parameters": {
        "jsCode": "function extractText(nodeName) {\n  try {\n    const item = $(nodeName).item;\n    if (!item || !item.json) return '(no data returned)';\n    const raw = item.json;\n    let payload = raw;\n    if (raw.content && Array.isArray(raw.content) && raw.content[0]) {\n      payload = raw.content[0].text !== undefined ? raw.content[0].text : raw.content[0];\n    } else if (Array.isArray(raw) && raw[0]) {\n      payload = raw[0].text !== undefined ? raw[0].text : raw[0];\n    }\n    if (typeof payload === 'string') {\n      const trimmed = payload.trim();\n      if (trimmed.startsWith('{') || trimmed.startsWith('[')) {\n        try { return JSON.stringify(JSON.parse(trimmed), null, 2); } catch(e) { return payload; }\n      }\n      return payload;\n    }\n    return JSON.stringify(payload, null, 2);\n  } catch(e) {\n    return `(extraction error: ${e.message})`;\n  }\n}\n\nconst ctx = $('Extract At-Risk Opps').item.json;\nreturn [{ json: {\n  opportunityName: ctx.opportunity_name,\n  accountName: ctx.account_name,\n  amount: ctx.amount,\n  engagementLevel: ctx.engagement_level,\n  closeDate: ctx.close_date,\n  owner: ctx.owner,\n  oppStatus: extractText('Get Opp Status'),\n  situationSearch: extractText('Situation Search')\n} }];"
      },
      "id": "fa1f3e03-d226-4f43-a697-f07c0b569a53",
      "name": "Merge Per Opp",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const j = $json;\nconst names = j.opportunityName || [];\nconst accs = j.accountName || [];\nconst amts = j.amount || [];\nconst engagements = j.engagementLevel || [];\nconst closes = j.closeDate || [];\nconst owners = j.owner || [];\nconst statuses = j.oppStatus || [];\nconst situations = j.situationSearch || [];\n\nconst oppBlocks = names.map((nm, i) => `### ${i+1}. ${nm}\nAccount: ${accs[i]} | Owner: ${owners[i]} | Amount: $${Number(amts[i]||0).toLocaleString()} | Close: ${closes[i]} | Engagement: ${engagements[i]}/100\nStatus: ${statuses[i] || 'N/A'}\nComparable: ${situations[i] || 'N/A'}`).join('\\n\\n');\n\nconst today = new Date().toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric'});\nconst dateShort = new Date().toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});\n\nconst prompt = `You are a sales forecasting assistant preparing a weekly pipeline review digest.\n\nToday: ${today}.\n\nTop at-risk opportunities (sorted by lowest engagement):\n\n${oppBlocks}\n\nProduce a Slack-formatted pipeline digest:\n\n:bar_chart: *Weekly Pipeline & Forecast Brief*\n_${dateShort}_\n\n*Pipeline Overview* — 2-3 sentence overall health summary\n\n*At-Risk Deals* — for each deal: name, risk level, primary signal, 1 recommended action\n\n*Situation Search Callouts* — patterns worth the team knowing (\"3 similar deals at this stage slipped — here's what closed them\")\n\n*This Week's Priorities* — top 3 deals or actions for the manager\n\nUnder 500 words. Be specific. No generic advice. Use Slack mrkdwn.`;\n\nreturn [{ json: { prompt } }];"
      },
