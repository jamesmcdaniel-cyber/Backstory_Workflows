},{"$ref":"#/components/parameters/Offset"},{"$ref":"#/components/parameters/Limit"}],"responses":{"200":{"$ref":"#/components/responses/EngagementList"},"400":{"$ref":"#/components/responses/BadRequest"},"401":{"$ref":"#/components/responses/Unauthorized"},"429":{"$ref":"#/components/responses/RateLimited"},"500":{"$ref":"#/components/responses/ServerError"}}}},"/pull/v1/export/activities/jobs":{"post":{"tags":["Bulk Export"],"summary":"Start a raw activity export job","operationId":"startActivityExportJob","description":"Start an asynchronous Raw Activity Data export. Poll the returned job, then download its data when complete.\n","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["start_date","end_date"],"properties":{"start_date":{"type":"string","format":"date","description":"Inclusive start date (YYYY-MM-DD)."},"end_date":{"type":"string","format":"date","description":"Inclusive end date (YYYY-MM-DD)."},"activity_type":{"type":"string","description":"Activity type to export, e.g. `all`.","default":"all"},"output_format":{"type":"string","description":"Output encoding, e.g. `JSONLines`.","example":"JSONLines"},"export_type":{"type":"string","description":"`snapshot` for a point-in-time export, or `delta` for changes.","example":"snapshot"}}},"example":{"start_date":"2026-01-01","end_date":"2026-03-31","activity_type":"all","output_format":"JSONLines","export_type":"snapshot"}}}},"responses":{"200":{"$ref":"#/components/responses/ExportJob"},"401":{"$ref":"#/components/responses/Unauthorized"}}},"get":{"tags":["Bulk Export"],"summary":"List recent activity export jobs","operationId":"listActivityExportJobs","description":"List activity export jobs initiated in the past 10 days.","responses":{"200":{"description":"A list of recent export jobs.","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/ExportJob"}}}}},"400":{"$ref":"#/components/responses/BadRequest"},"401":{"$ref