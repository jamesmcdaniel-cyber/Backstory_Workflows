ne"},{"$ref":"#/components/parameters/IngestFrom"},{"$ref":"#/components/parameters/IngestTo"},{"$ref":"#/components/parameters/InternalExternal"},{"$ref":"#/components/parameters/IncludeDeleted"},{"$ref":"#/components/parameters/Uid"},{"$ref":"#/components/parameters/Offset"},{"$ref":"#/components/parameters/Limit"}],"responses":{"200":{"$ref":"#/components/responses/ActivityList"},"400":{"$ref":"#/components/responses/BadRequest"},"401":{"$ref":"#/components/responses/Unauthorized"},"429":{"$ref":"#/components/responses/RateLimited"},"500":{"$ref":"#/components/responses/ServerError"}}}},"/v0/public/activities/{activityType}":{"get":{"tags":["Activities"],"summary":"List activities of a type","operationId":"listActivitiesByType","description":"Return company activities for the given `activityType` within a time range. If no range is specified, a 30-day range is enforced.\n","parameters":[{"name":"activityType","in":"path","required":true,"description":"Activity type to fetch.","schema":{"type":"string","enum":["email","call","meeting"]}},{"$ref":"#/components/parameters/AccountIdQuery"},{"$ref":"#/components/parameters/OpportunityIdQuery"},{"$ref":"#/components/parameters/From"},{"$ref":"#/components/parameters/To"},{"$ref":"#/components/parameters/LastNDays"},{"$ref":"#/components/parameters/TimeZone"},{"$ref":"#/components/parameters/IngestFrom"},{"$ref":"#/components/parameters/IngestTo"},{"$ref":"#/components/parameters/InternalExternal"},{"$ref":"#/components/parameters/IncludeDeleted"},{"$ref":"#/components/parameters/Uid"},{"$ref":"#/components/parameters/Offset"},{"$ref":"#/components/parameters/Limit"}],"responses":{"200":{"$ref":"#/components/responses/ActivityList"},"400":{"$ref":"#/components/responses/BadRequest"},"401":{"$ref":"#/components/responses/Unauthorized"},"429":{"$ref":"#/components/responses/RateLimited"},"500":{"$ref":"#/components/responses/ServerError"}}}},"/v0/public/activities/participants":{"get":{"tags":["Activities"],"summary":"Lis