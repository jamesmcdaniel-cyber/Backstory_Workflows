{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://backstory.ai/schemas/customer-stack-config.schema.json",
  "title": "Backstory Customer Stack Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "customer",
    "implementation",
    "selected_packs",
    "env_bindings",
    "routing_defaults",
    "field_overrides",
    "threshold_overrides",
    "certification"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "owner_email"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "segment": {
          "type": "string"
        },
        "owner_email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_id",
        "target_orchestrator",
        "starter_variant",
        "rollout_mode",
        "go_live_region"
      ],
      "properties": {
        "workflow_id": {
          "type": "string",
          "pattern": "^\\d{2}-[a-z0-9-]+$"
        },
        "target_orchestrator": {
          "type": "string",
          "enum": [
            "n8n",
            "workato",
            "zapier",
            "power-automate",
            "make",
            "custom-code"
          ]
        },
        "starter_variant": {
          "type": "string",
          "enum": [
            "starter.json",
            "full.json",
            "guide_only"
          ]
        },
        "rollout_mode": {
          "type": "string",
          "enum": [
            "pilot",
            "production"
          ]
        },
        "go_live_region": {
          "type": "string",
          "minLength": 2
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "selected_packs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "pack_id",
          "connection_ref",
          "enabled"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "crm",
              "delivery",
              "meeting_source",
              "identity",
              "orchestrator"
            ]
          },
          "pack_id": {
            "type": "string"
          },
          "connection_ref": {
            "type": "string",
            "minLength": 2
          },
          "enabled": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "env_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "value_source",
          "secret"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "value_source": {
            "type": "string",
            "enum": [
              "workspace_env",
              "secret_manager",
              "manual",
              "derived"
            ]
          },
          "secret": {
            "type": "boolean"
          },
          "value": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "routing_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_destination",
        "summary_destination",
        "owner_fallback"
      ],
      "properties": {
        "default_destination": {
          "type": "string",
          "minLength": 2
        },
        "summary_destination": {
          "type": "string",
          "minLength": 2
        },
        "owner_fallback": {
          "type": "string",
          "enum": [
            "channel",
            "direct_message",
            "email",
            "none"
          ]
        },
        "escalation_destination": {
          "type": "string"
        }
      }
    },
    "field_overrides": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "crm",
        "delivery",
        "meeting_source"
      ],
      "properties": {
        "crm": {
          "type": "object",
          "additionalProperties": true
        },
        "delivery": {
          "type": "object",
          "additionalProperties": true
        },
        "meeting_source": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "threshold_overrides": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_scenarios",
        "approvers"
      ],
      "properties": {
        "required_scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "approvers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "email"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
