# Required: server-side Anthropic key for the assistant (/api/chat).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: chat model. Default claude-opus-4-8; set claude-sonnet-4-6 to cut cost/latency.
ANTHROPIC_MODEL=claude-opus-4-8

# For marketplace submissions (/api/submit). Repo-scoped token that can open issues.
GITHUB_TOKEN=ghp_...
GITHUB_REPO=JamesMcDaniel04/Backstory_Workflows
